---
import Layout from '../layouts/Layout.astro';

const sources = [
	{
		label: 'Noblesville Parks & Trails',
		href: 'https://www.noblesville.in.gov/640/Parks-Trails',
		note: 'Documents 876 acres of parkland, 130 miles of trails, Forest Park, and the citywide trail network.',
	},
	{
		label: 'Forest Park',
		href: 'https://www.noblesville.in.gov/755/Forest-Park',
		note: 'Official page for a 150-acre flagship park that helps define Noblesville’s open-space identity.',
	},
	{
		label: 'Greenways & Trails From Forest Park',
		href: 'https://www.noblesville.in.gov/772/Greenways-Trails-From-Forest-Park',
		note: 'Describes the White River Greenway, downtown connection, and broader trail links across Noblesville.',
	},
	{
		label: 'Fox Prairie & Forest Park Golf Courses',
		href: 'https://www.noblesvilleparksgolf.com/',
		note: 'Official golf-course site describing Fox Prairie and Forest Park Golf Course as public recreation anchors.',
	},
	{
		label: 'Noblesville Soccer Fields',
		href: 'https://www.noblesville.in.gov/723/Soccer-Fields',
		note: 'Official page for a major youth soccer complex that adds family recreation energy to Noblesville.',
	},
	{
		label: 'All In Noblesville Comprehensive Plan Update',
		href: 'https://www.noblesville.in.gov/m/newsflash/home/detail/59',
		note: 'City planning initiative for land use, development, community assets, and growth over the next 20 years.',
	},
	{
		label: 'Embrace Downtown Noblesville',
		href: 'https://www.noblesville.in.gov/m/newsflash/home/detail/49',
		note: 'Downtown improvement effort focused on a welcoming, accessible, vibrant downtown economy.',
	},
	{
		label: 'Reimagine Pleasant Street',
		href: 'https://www.noblesville.in.gov/m/newsflash/home/detail/31',
		note: 'Major east-west mobility and trail-connection project through the heart of Noblesville.',
	},
	{
		label: 'Innovation Mile Growth',
		href: 'https://www.noblesville.in.gov/m/newsflash/home/detail/25',
		note: 'City economic-development release describing Noblesville growth momentum around advanced industries, sports, and technology.',
	},
];
---

<Layout>
	<main class="research-shell">
		<section class="hero" aria-label="Location research for Baker James Farm">
			<nav class="nav" aria-label="Main navigation">
				<a class="brand" href="/">
					<img src="/logo-mark.svg" alt="" width="40" height="40" />
					<span>Baker James Farm</span>
				</a>
				<div class="nav-links">
					<a href="/">Home</a>
					<a href="#rationale">Rationale</a>
					<a href="#sources">Sources</a>
				</div>
			</nav>

			<div class="hero-content">
				<p class="eyebrow">Location research | Noblesville, Indiana</p>
				<h1>Open-space living beside downtown energy.</h1>
				<p>
					Baker James Farm is framed around a rare Noblesville idea: countryside-style
					open space with practical access to downtown, parks, trails, golf, youth sports,
					and broader recreation corridors.
				</p>
			</div>
		</section>

		<section class="section thesis" id="rationale">
			<div>
				<p class="label">Why this makes sense</p>
				<h2>A countryside concept belongs where town, park, trail, and destination traffic already overlap.</h2>
			</div>
			<div class="narrative">
				<p>
					Baker James Farm does not need to manufacture a sense of place from scratch. The
					Noblesville context already has the ingredients that make an open-space homestead
					and agritourism operation legible: mature parkland, established recreation,
					nearby downtown restaurants and small businesses, and corridors that connect
					neighborhoods with outdoor destinations.
				</p>
				<p>
					That mix supports a quiet residential product and a light-touch public experience.
					The land can stay visually green and low-density while still being close enough to
					downtown Noblesville for guests, buyers, and community partners to understand the
					project as part of the city rather than a remote rural outpost.
				</p>
			</div>
		</section>

		<section class="proof-grid" aria-label="Location proof points">
			<article>
				<span>01</span>
				<h3>Forest Park anchors Noblesville's open-space identity.</h3>
				<p>
					Noblesville describes Forest Park as a 150-acre flagship park with trails, golf,
					aquatic facilities, shelters, courts, event spaces, and community programming.
					That civic landscape supports the same open-space values Baker James Farm wants
					to emphasize: private gardens, prairie, orchards, and farm-venue programming.
				</p>
				<a href="https://www.noblesville.in.gov/755/Forest-Park">Forest Park source</a>
			</article>

			<article>
				<span>02</span>
				<h3>Fox Prairie reinforces a low-density recreation character.</h3>
				<p>
					Fox Prairie Golf Course is an established public recreation asset in Noblesville.
					It strengthens the case for a landscape-led residential concept: long views,
					managed green space, and a familiar leisure identity instead of a purely suburban
					subdivision feel.
				</p>
				<a href="https://www.noblesvilleparksgolf.com/">Golf course source</a>
			</article>

			<article>
				<span>03</span>
				<h3>Soccer fields add family and tournament energy.</h3>
				<p>
					The Noblesville Soccer Fields include multiple regulation-sized fields and host
					local leagues, practices, and youth tournaments. That reinforces the city's
					family-oriented recreation culture without requiring a farm experience to sit in
					the middle of downtown traffic.
				</p>
				<a href="https://www.noblesville.in.gov/723/Soccer-Fields">Soccer fields source</a>
			</article>

			<article>
				<span>04</span>
				<h3>The trail network ties parks, neighborhoods, and downtown together.</h3>
				<p>
					Noblesville identifies the White River Greenway as the connection between Forest Park
					and downtown. The city also describes trail links that continue across the community.
					That gives Baker James Farm a credible open-space narrative with nearby trail logic.
				</p>
				<a href="https://www.noblesville.in.gov/772/Greenways-Trails-From-Forest-Park">Trail source</a>
			</article>
		</section>

		<section class="section downtown">
			<div>
				<p class="label">Downtown proximity</p>
				<h2>Close enough to downtown to matter, far enough out to feel pastoral.</h2>
			</div>
			<div class="narrative">
				<p>
					The Noblesville setting lets the project benefit from the city's active investment
					in downtown access, streetscape, and small business vitality while preserving the
					quieter experience that buyers expect from multi-acre estate living.
				</p>
				<p>
					For the farm-venue side of the operation, this is important. Guests can pair a farm
					stand day, workshop, garden visit, or private event with downtown dining and shopping.
					For residents, the same proximity keeps daily life practical: the homes can feel
					country-like without asking owners to give up town access.
				</p>
			</div>
		</section>

		<section class="location-band" aria-label="Open-space positioning">
			<div>
				<p class="label">Positioning</p>
				<h2>Not a subdivision with leftover green space. An open-space place with homes carefully set inside it.</h2>
			</div>
			<p>
				The strongest version of Baker James Farm is not density first. It is landscape first:
				private acreage, a dedicated farm-venue lot, restored native habitat, invasive-species
				cleanup, orchard rows, walking paths, garden rooms, and small-scale public programming
				near the entry. That restoration land can function as a wildlife movement corridor
				near the White River edge while the nearby civic anchors remain outdoor,
				recreational, and community-facing.
			</p>
		</section>

		<section class="source-section" id="sources">
			<div>
				<p class="label">Research links</p>
				<h2>Source material</h2>
			</div>
			<div class="source-list">
				{sources.map((source) => (
					<a href={source.href}>
						<strong>{source.label}</strong>
						<span>{source.note}</span>
					</a>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(html) {
		scroll-behavior: smooth;
		background: #f7f3eb;
		color: #1e241d;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.research-shell {
		min-height: 100vh;
		background: #f7f3eb;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.hero {
		position: relative;
		min-height: 76vh;
		display: grid;
		align-content: space-between;
		padding: 24px clamp(18px, 4vw, 56px) 72px;
		overflow: hidden;
		background:
			linear-gradient(90deg, rgba(15, 17, 12, 0.92), rgba(15, 17, 12, 0.42)),
			url("/images/baker-james-farm-venue-gardens.png") center / cover;
		color: #fffdf6;
	}

	.nav {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 14px 16px;
		border: 1px solid rgba(255, 253, 246, 0.24);
		border-radius: 8px;
		background: rgba(15, 17, 12, 0.72);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font-size: clamp(1.15rem, 2vw, 1.55rem);
		font-weight: 800;
	}

	.brand img {
		width: 40px;
		height: 40px;
		border-radius: 8px;
	}

	.nav-links {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(14px, 3vw, 32px);
		font-weight: 700;
	}

	.hero-content {
		position: relative;
		z-index: 1;
		max-width: 960px;
		padding-top: 18vh;
	}

	.eyebrow,
	.label {
		margin: 0 0 14px;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.eyebrow {
		color: #f7c948;
	}

	.label {
		color: #7c3f22;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 900px;
		margin-bottom: 18px;
		font-size: clamp(2.9rem, 6vw, 6.4rem);
		line-height: 0.96;
	}

	h2 {
		margin-bottom: 0;
		font-size: clamp(2rem, 4vw, 4.25rem);
		line-height: 1;
	}

	h3 {
		margin-bottom: 12px;
		font-size: 1.45rem;
		line-height: 1.1;
	}

	.hero-content p:last-child {
		max-width: 720px;
		color: #f4ead7;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		line-height: 1.55;
	}

	.section,
	.source-section {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(280px, 1.05fr);
		gap: clamp(28px, 5vw, 72px);
		padding: clamp(56px, 9vw, 112px) clamp(18px, 4vw, 56px);
	}

	.thesis {
		background: #f7f3eb;
	}

	.narrative {
		display: grid;
		gap: 18px;
		color: #53594e;
		font-size: 1.1rem;
		line-height: 1.75;
	}

	.proof-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1px;
		background: #ded4c3;
		border-block: 1px solid #ded4c3;
	}

	article {
		min-height: 420px;
		display: grid;
		align-content: start;
		gap: 18px;
		padding: clamp(22px, 3vw, 34px);
		background: #fffaf0;
	}

	article span {
		color: #a65f34;
		font-weight: 900;
	}

	article p {
		color: #5e6357;
		line-height: 1.65;
	}

	article a,
	.source-list a {
		align-self: end;
		display: inline-flex;
		width: fit-content;
		border-bottom: 2px solid #a65f34;
		color: #7c3f22;
		font-weight: 900;
	}

	.downtown {
		background: #24311f;
		color: #fffdf6;
	}

	.downtown .label {
		color: #f7c948;
	}

	.downtown .narrative {
		color: #f7f0df;
	}

	.location-band {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
		gap: clamp(28px, 5vw, 72px);
		align-items: end;
		padding: clamp(64px, 10vw, 124px) clamp(18px, 4vw, 56px);
		background:
			linear-gradient(0deg, rgba(12, 15, 10, 0.9), rgba(12, 15, 10, 0.5)),
			url("/images/baker-james-farm-venue-gardens.png") center / cover;
		color: #fffdf6;
	}

	.location-band .label {
		color: #f7c948;
	}

	.location-band p:last-child {
		margin-bottom: 0;
		color: #f7f0df;
		font-size: 1.15rem;
		line-height: 1.75;
	}

	.source-section {
		background: #f7f3eb;
	}

	.source-list {
		display: grid;
		gap: 14px;
	}

	.source-list a {
		width: auto;
		display: grid;
		gap: 8px;
		padding: 18px 0;
		border-bottom: 1px solid #ded4c3;
	}

	.source-list span {
		color: #5e6357;
		font-weight: 500;
		line-height: 1.5;
	}

	@media (max-width: 1040px) {
		.proof-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 820px) {
		.nav {
			align-items: flex-start;
			flex-direction: column;
		}

		.section,
		.source-section,
		.location-band {
			grid-template-columns: 1fr;
		}

		.proof-grid {
			grid-template-columns: 1fr;
		}

		article {
			min-height: 0;
		}
	}
</style>

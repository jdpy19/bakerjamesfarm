---
import Layout from "../layouts/Layout.astro";
import { features } from "../config/features";
import { draftPages, getDraftPage } from "../content/draftPages";

export function getStaticPaths() {
	if (!features.draftPages) {
		return [];
	}

	return draftPages.map((page) => ({
		params: { draft: page.slug },
		props: { page },
	}));
}

const { draft } = Astro.params;
const page = Astro.props.page ?? (draft ? getDraftPage(draft) : undefined);

if (!page) {
	return Astro.redirect("/");
}
---

<Layout>
	<main class="draft-shell">
		<nav class="draft-nav" aria-label="Draft page navigation">
			<a class="brand" href="/">Baker James Farm</a>
			<a href="/">Back to site</a>
		</nav>

		<section class="draft-hero">
			<p class="eyebrow">{page.eyebrow}</p>
			<h1>{page.title}</h1>
			<p>{page.intro}</p>
		</section>

		<section class="draft-grid" aria-label="Draft sections">
			{page.sections.map((section) => (
				<article>
					<h2>{section.title}</h2>
					<p>{section.body}</p>
					{section.items && (
						<ul>
							{section.items.map((item) => <li>{item}</li>)}
						</ul>
					)}
				</article>
			))}
		</section>
	</main>
</Layout>

<style>
	:global(html) {
		background: #f7f3eb;
		color: #1e241d;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.draft-shell {
		min-height: 100vh;
		background:
			linear-gradient(90deg, rgba(15, 17, 12, 0.92), rgba(15, 17, 12, 0.56)),
			url("/images/baker-james-farm-venue-gardens.png") center / cover fixed;
		color: #fffdf6;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.draft-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		margin: 0 clamp(18px, 4vw, 56px);
		padding: 24px 0;
		font-weight: 800;
	}

	.brand {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
	}

	.draft-hero {
		max-width: 860px;
		padding: clamp(64px, 12vw, 144px) clamp(18px, 4vw, 56px) clamp(48px, 8vw, 88px);
	}

	.eyebrow {
		margin: 0 0 14px;
		color: #f7c948;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 18px;
		font-size: clamp(2.9rem, 6vw, 6rem);
		line-height: 0.95;
	}

	.draft-hero p:last-child {
		max-width: 680px;
		color: #f4ead7;
		font-size: clamp(1.05rem, 2vw, 1.3rem);
		line-height: 1.6;
	}

	.draft-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		padding: 0 clamp(18px, 4vw, 56px) clamp(56px, 9vw, 112px);
	}

	article {
		min-height: 280px;
		padding: clamp(24px, 4vw, 36px);
		border: 1px solid rgba(255, 253, 246, 0.22);
		border-radius: 8px;
		background: rgba(15, 17, 12, 0.78);
	}

	h2 {
		margin-bottom: 14px;
		font-size: clamp(1.8rem, 3vw, 3rem);
		line-height: 1;
	}

	article p,
	li {
		color: #f7f0df;
		line-height: 1.65;
	}

	ul {
		display: grid;
		gap: 10px;
		margin: 24px 0 0;
		padding-left: 20px;
	}

	@media (max-width: 760px) {
		.draft-nav {
			align-items: flex-start;
			flex-direction: column;
		}

		.draft-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

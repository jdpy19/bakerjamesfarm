{
  "name": "bakerjamesfarm",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
	"scripts": {
		"dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
		"dev:drafts": "SHOW_DRAFT_PAGES=true ASTRO_TELEMETRY_DISABLED=1 astro dev",
		"build": "SHOW_DRAFT_PAGES=false ASTRO_TELEMETRY_DISABLED=1 astro build",
		"build:drafts": "SHOW_DRAFT_PAGES=true ASTRO_TELEMETRY_DISABLED=1 astro build",
		"deploy": "./scripts/deploy.sh",
		"preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
		"preview:drafts": "npm run build:drafts && ASTRO_TELEMETRY_DISABLED=1 astro preview",
		"astro": "astro"
	},
  "dependencies": {
    "astro": "^7.0.3"
  }
}
